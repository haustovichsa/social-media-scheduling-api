# Runtime environment: development | test | production
NODE_ENV=development

# HTTP server port
PORT=3000

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/social-media-scheduling

# Dev API keys for request auth, as comma-separated `apiKey:orgId` pairs.
# Callers present one as `Authorization: Bearer <apiKey>`; the key resolves to a
# tenant that scopes every query (A-6). Replaced by a real authenticator in prod.
SOCIAL_API_KEYS=devkey-org1:org-1,devkey-org2:org-2
